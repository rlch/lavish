{
  "name": "@rlch/lavish",
  "version": "1.0.0",
  "private": true,
  "description": "Annotation-only HTML review surface for the cmux workflow: queue element annotations on a rich artifact and send them straight back to your agent. Fork of lavish-axi.",
  "type": "module",
  "bin": {
    "lavish": "dist/cli.mjs",
    "lavish-axi": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "check": "npm run build && npm run lint && npm run format:check && npm run typecheck && npm test",
    "start": "node dist/cli.mjs",
    "lint": "eslint bin src test scripts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/browser": "4.2.4",
    "axi-sdk-js": "^0.1.7",
    "chokidar": "^4.0.3",
    "daisyui": "^5.5.19",
    "express": "^5.2.1",
    "open": "^10.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "cmux",
    "annotation",
    "review",
    "html",
    "agent",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rlch/lavish.git"
  },
  "bugs": {
    "url": "https://github.com/rlch/lavish/issues"
  },
  "homepage": "https://github.com/rlch/lavish#readme",
  "author": "Richard Mathieson <rjm.hjkl@gmail.com>"
}
